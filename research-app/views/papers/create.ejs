<% locals.activePage = 'upload' %>
<%- include('../layout-top') %>

<div class="page-header">
  <div>
    <h1>Upload Research Paper</h1>
    <p>Fill in all fields and attach the PDF file</p>
  </div>
  <a href="/papers" class="btn btn-secondary">← Back to Papers</a>
</div>

<div class="card" style="max-width:760px;">
  <div class="card-body">
    <form action="/papers/create" method="POST" enctype="multipart/form-data">
      <div class="form-group">
        <label class="form-label">Paper Title *</label>
        <input type="text" name="title" class="form-control" placeholder="Enter the full title of the paper" required />
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Author(s) *</label>
          <input type="text" name="author" class="form-control" placeholder="e.g. John Doe, Jane Smith" required />
        </div>
        <div class="form-group">
          <label class="form-label">Publication Year *</label>
          <input type="number" name="year" class="form-control" placeholder="e.g. 2024" min="1900" max="2030" required />
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Category *</label>
        <select name="category" class="form-control" required>
          <option value="">— Select a category —</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat %>"><%= cat %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label class="form-label">Abstract *</label>
        <textarea name="abstract" class="form-control" rows="5" placeholder="Paste or type the paper abstract here..." required></textarea>
      </div>

      <div class="form-group">
        <label class="form-label">PDF File *</label>
        <input type="file" name="pdfFile" class="form-control" accept="application/pdf" required />
        <div class="form-hint">PDF only. Maximum file size: 20 MB.</div>
      </div>

      <div class="flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary btn-lg">⬆️ Upload Paper</button>
        <a href="/papers" class="btn btn-secondary btn-lg">Cancel</a>
      </div>
    </form>
  </div>
</div>

<%- include('../layout-bottom') %>
