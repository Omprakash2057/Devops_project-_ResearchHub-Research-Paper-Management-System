<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>500 — Server Error</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:12px;text-align:center;padding:24px;">
  <div style="font-size:80px;">⚠️</div>
  <h1 style="font-size:48px;font-weight:700;color:#ef4444;">500</h1>
  <p style="font-size:18px;font-weight:600;">Internal Server Error</p>
  <p style="color:#64748b;max-width:400px;"><%= typeof message !== 'undefined' ? message : 'Something went wrong on our end.' %></p>
  <a href="/dashboard" class="btn btn-primary btn-lg" style="margin-top:12px;">Go to Dashboard</a>
</div>
</body>
</html>
